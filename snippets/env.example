# Copy to .env.local and fill in.

# ---- Database ----------------------------------------------------------
# Postgres connection string. Any Postgres works; the CMS was built
# against Dokwe's managed Postgres.
DATABASE_URI=postgresql://user:password@host:port/dbname

# ---- Auth.js ------------------------------------------------------------
# Session secret. Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Trust the incoming Host header (needed on most managed hosts).
AUTH_TRUST_HOST=true

# ---- Object storage (S3-compatible) ------------------------------------
# Any S3 protocol backend works. lib/storage.ts is configured for Dokwe's
# path-style endpoint pattern (https://<slug>-s3.dokwe.com).
DOKWE_SLUG=my-space
DOKWE_STORAGE_KEY=
DOKWE_SECRET=

# ---- Optional: initial admin seed --------------------------------------
# Consumed by scripts/seed.ts on first run.
ADMIN_EMAIL=you@example.org
ADMIN_PASSWORD=change-me
ADMIN_NAME=First Editor

# ---- Optional: in-CMS "check for updates" flow -------------------------
# Points at the CMS repo's canonical version.json (raw file).
CMS_MANIFEST_URL=https://raw.githubusercontent.com/FregateLab/flashcms/main/version.json

# Deploy hook URL. When admin clicks "Trigger update", the CMS POSTs to
# this URL. Configure on your host so the POST causes a rebuild:
#   - Dokwe: use a deploy-hook URL from the app dashboard
#   - Vercel: use a Deploy Hook (Settings -> Git -> Deploy Hooks)
#   - GitHub Actions: use a workflow_dispatch webhook
CMS_UPDATE_WEBHOOK_URL=

# Optional shared secret. When set, the CMS signs the POST body as
#   x-cms-signature: sha256=<hex>
# so your receiver can verify authenticity.
CMS_UPDATE_WEBHOOK_SECRET=
